# Geocoding API + Solar API + Places API (New) — one GCP key, all 3 enabled, billing required.
# Get it: console.cloud.google.com -> select/create project -> APIs & Services -> Library
#   -> enable "Geocoding API", "Solar API", "Places API (New)"
#   -> APIs & Services -> Credentials -> Create Credentials -> API key
#   -> (recommended) restrict the key to just those 3 APIs.
GOOGLE_MAPS_API_KEY=

# EIA API v2 — instant free key, no billing needed.
# Get it: api.eia.gov/register/
EIA_API_KEY=

# Vercel AI Gateway — auto-present once this repo is linked to a Vercel project.
# For local dev only: Vercel dashboard -> AI Gateway -> API Keys.
AI_GATEWAY_API_KEY=

# Clerk authentication. Copy keys from the Clerk Dashboard; never commit values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/challenge
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/challenge

# --- Not needed yet — persistence remains stubbed until wired ---
# DATABASE_URL=
